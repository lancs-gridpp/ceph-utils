# ── Column index constants ───────────────────────────────────────────────────
# Each constant is the index into COLUMNS for that column.
# Use these everywhere instead of repeating the header string.
COL_STATUS           = 0
COL_RANK             = 1
COL_CLIENT_NAME      = 2
COL_CLIENT_ID        = 3
COL_UID              = 4
COL_OP_TYPE          = 5
COL_REQUEST          = 6
COL_FILENAME            = 7
COL_FLAG_POINT       = 8
COL_SKEW             = 9
COL_DURATION         = 10
COL_DURATION_S       = 11
COL_DURATION_STR     = 12
COL_DURATION_WRAPPED = 13

# COLUMNS is the single source of truth for header label and minimum width.
# All rendering code references columns by the COL_* constants above.
COLUMNS = [
    (COL_STATUS,     "Status",      7),
    (COL_RANK,       "MDS Rank",    8),
    (COL_CLIENT_NAME,"Client",     12),
    (COL_CLIENT_ID,  "Client ID",   6),
    (COL_UID,        "UID",         6),
    (COL_OP_TYPE,    "Op Type",    16),
    (COL_REQUEST,    "Request",    10),
    (COL_FILENAME,   "Inode",      28),
    (COL_FLAG_POINT, "Flag Point", 36),
    (COL_SKEW,       "Skew",       10),
    (COL_DURATION,   "Duration",   12),
]

def _col_widths(rows):
    # type: (List[Dict]) -> Dict[int, int]
    """Return a mapping of COL_* -> display width, expanded to fit row data."""
    widths = {idx: w for idx, _label, w in COLUMNS}
    for row in rows:
        try:
            widths[COL_CLIENT_NAME] = max(widths[COL_CLIENT_NAME], len(row[COL_CLIENT_NAME]))
            widths[COL_CLIENT_ID]   = max(widths[COL_CLIENT_ID],   len(row[COL_CLIENT_ID]))
            widths[COL_OP_TYPE]     = max(widths[COL_OP_TYPE],     len(row[COL_OP_TYPE]))
            widths[COL_REQUEST]     = max(widths[COL_REQUEST],     len(row[COL_REQUEST]))
            widths[COL_FILENAME]    = max(widths[COL_FILENAME],    len(row[COL_FILENAME]))
            widths[COL_FLAG_POINT]  = max(widths[COL_FLAG_POINT],  len(row[COL_FLAG_POINT]))
            widths[COL_SKEW]        = max(widths[COL_SKEW],        len(row[COL_SKEW]))
            widths[COL_DURATION]    = max(widths[COL_DURATION],    len(row[COL_DURATION_STR]))
            widths[COL_STATUS]      = max(widths[COL_STATUS],      len(row[COL_STATUS]))
        except Exception as e:
            # Debug code.
            print(row)
            raise e
    return widths


def render_table(rows):
    # type: (List[Dict]) -> None
    if not rows:
        print(colourise("  No ops in flight.", GREEN))
        return

    widths = _col_widths(rows)

    def cell(text, col):
        # type: (object, int) -> str
        return str(text).ljust(widths[col])

    sep_parts  = ["-" * widths[idx] for idx, _label, _w in COLUMNS]
    separator  = "-+-".join(sep_parts)

    header_parts = [colourise(cell(_label, idx), BOLD, CYAN) for idx, _label, _w in COLUMNS]
    header = " | ".join(header_parts)

    print(header)
    print(colourise(separator, DIM))

    for row in rows:
        duration = row[COL_DURATION_S]
        if row.get(COL_DURATION_WRAPPED):
            dur_colour = CYAN
        elif duration >= 30:
            dur_colour = RED
        elif duration >= 5:
            dur_colour = YELLOW
        else:
            dur_colour = RESET

        skew        = row[COL_SKEW]
        skew_colour = RED if "(!)" in skew else YELLOW if skew not in ("~0", "n/a") else RESET
        status      = row[COL_STATUS]
        status_col  = STATUS_COLOUR.get(status, RESET)

        parts = [
            colourise( cell(status,COL_STATUS),  status_col, BOLD),
            colourise( cell(row[COL_RANK],COL_RANK), BOLD),
            colourise( cell(row[COL_CLIENT_NAME],COL_CLIENT_NAME), CYAN),
            colourise( cell(row[COL_CLIENT_ID],COL_CLIENT_ID), CYAN),
            cell(row[COL_UID],COL_UID),
            cell(row[COL_OP_TYPE],COL_OP_TYPE),
            colourise(cell(row[COL_REQUEST],COL_REQUEST), CYAN),
            colourise(cell(row[COL_FILENAME],COL_FILENAME), DIM),
            colourise(cell(row[COL_FLAG_POINT], COL_FLAG_POINT), DIM),
            colourise(cell(skew,COL_SKEW), skew_colour),
            colourise(cell(row[COL_DURATION_STR], COL_DURATION), dur_colour),
        ]
        print(" | ".join(parts))

    print(colourise(separator, DIM))
    total   = len(rows)
    counts  = {}
    for r in rows:
        counts[r[COL_STATUS]] = counts.get(r[COL_STATUS], 0) + 1

    # Human-readable label for each status tag shown in the summary line
    SUMMARY_LABEL = {
        "WRAP":    "WRAP (age counter overflowed, real duration shown)",
        "ZOMBIE":  "ZOMBIE (timer never initialised, likely stale)",
        "HUNG":    "HUNG (>1 hour, possibly stuck)",
        "SLOW":    "SLOW (>30s)",
        "SKEW(!)": "SKEW! (clock skew >=30s)",
        "SKEW":    "SKEW (clock skew >=1s)",
        "OK":      "OK",
    }

    print("\n  Total ops: {}".format(colourise(total, BOLD)), end="")
    for tag in ("WRAP", "ZOMBIE", "HUNG", "SLOW", "SKEW(!)", "SKEW", "OK"):
        n = counts.get(tag, 0)
        if n:
            col   = STATUS_COLOUR.get(tag, RESET)
            label = SUMMARY_LABEL.get(tag, tag)
            print("  |  {}".format(colourise("{} {}".format(n, label), col, BOLD)), end="")
    print()


# ── Main ─────────────────────────────────────────────────────────────────────

def build_rows(rank, ops, client_map, show_file_name):
    # type: (int, List[Dict], Dict[int, str], bool) -> List[Dict]
    rows = []
    for op in ops:
        client_id = extract_client_id(op)
        if client_id is not None:
            client_name = client_map.get(client_id,"")
            # client_name = client_map.get(
            #     client_id,
            #     "client.{}".format(client_id)   # fallback if not in session list
            # )
        else:
            client_name = "unknown"

        dur_s, dur_str, dur_wrapped = duration_info(op)
        skew   = extract_clock_skew(op)
        status = classify_op_status(dur_s, skew, is_wrapped=dur_wrapped)
        rows.append({
            COL_RANK:             str(rank),
            COL_CLIENT_NAME:      client_name,
            COL_CLIENT_ID:        str(client_id),
            COL_UID:              extract_caller_uid(op),
            COL_OP_TYPE:          extract_op_type(op),
            COL_REQUEST:          extract_request_subtype(op),
            COL_FILENAME:         extract_filename(op,show_file_name),
            COL_FLAG_POINT:       extract_flag_point(op),
            COL_SKEW:             skew,
            COL_STATUS:           status,
            COL_DURATION_S:       dur_s,
            COL_DURATION_STR:     dur_str,
            COL_DURATION_WRAPPED: dur_wrapped,
        })
    return rows


SORT_KEYS = {
    "duration": lambda r: r[COL_DURATION_S],
    "client":   lambda r: r[COL_CLIENT_NAME].lower(),
    "type":     lambda r: r[COL_OP_TYPE].lower(),
    "uid":      lambda r: r[COL_UID],
}


def main():
    # type: () -> None
    parser = argparse.ArgumentParser(
        description="Show Ceph MDS in-flight ops as a formatted table.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--sort", "-s",
        choices=list(SORT_KEYS),
        default="duration",
        help="Column to sort by (default: duration, descending)",
    )
    parser.add_argument(
        "--min-duration", "-m",
        type=float,
        default=0.0,
        metavar="SECS",
        help="Only show ops older than this many seconds (default: 0 = all)",
    )
    parser.add_argument(
        "--rank", "-r",
        type=int,
        default=None,
        metavar="N",
        help="Query a specific MDS rank only (default: all active ranks)",
    )
    parser.add_argument(
        "--file-name", "-f",
        action="store_true",
        help="Show file name",
    )
    args = parser.parse_args()

    ranks = [args.rank] if args.rank is not None else get_active_mds_ranks()

    # Remove File Name from the column definitions if it isn't needed.
    if args.file_name:
        global COLUMNS
        COLUMNS = [
            (idx,
            "File Name" if idx == COL_FILENAME else label,
            width)
            for idx, label, width in COLUMNS
        ]

    if not ranks:
        print("No active MDS ranks to query.")
        sys.exit(0)

    all_rows = []

    for rank in ranks:
        print(colourise("Querying MDS rank {} ...".format(rank), DIM), file=sys.stderr)

        client_map = get_client_name_map(rank)
        ops        = get_ops_in_flight(rank)

        if not ops:
            print(colourise("  mds.{}: no ops in flight.".format(rank), DIM), file=sys.stderr)
            continue

        rows = build_rows(rank, ops, client_map, args.file_name)
        all_rows.extend(rows)

    # Filter
    if args.min_duration > 0:
        all_rows = [r for r in all_rows if r[COL_DURATION_S] >= args.min_duration]

    # Sort (descending for duration, ascending for everything else)
    reverse = args.sort == "duration"
    all_rows.sort(key=SORT_KEYS[args.sort], reverse=reverse)

    print()
    render_table(all_rows)
    print()


if __name__ == "__main__":
    main()
